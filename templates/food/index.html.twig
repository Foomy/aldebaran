{% extends 'base.html.twig' %}

{% block title %}{{ "title.food.list" | trans }}{% endblock %}

{% block body %}
<table class="food-list table">
    <thead>
        <tr>
            <th>#</th>
            <th>{{ "food.name" | trans }}</th>
            <th>{{ "food.nutritionValue" | trans }}</th>
            <th>{{ "food.protein" | trans }}</th>
            <th>{{ "food.fat" | trans }}</th>
            <th>{{ "food.roughage" | trans }}</th>
            <th>{{ "food.carbonhydrate" | trans }}</th>
            <th>{{ "food.description" | trans }}</th>
            <th>{{ "food.actions" | trans }}</th>
        </tr>
        <tr>
            <td colspan="8"></td>
            <td><button type="button" class="btn btn-success" data-js="is-add-btn" title="{{ "food.action.add" | trans }}"><i class="fas fa-circle-plus"></i></button></td>
        </tr>
    </thead>
    <tfoot></tfoot>
    {% if (foods | length > 0) %}
    <tbody>
        {% for food in foods %}
            <tr>
                <td>{{ food.id }}</td>
                <td>{{ food.name }}</td>
                <td>{{ food.nutritionValue }}</td>
                <td>{{ food.protein }}</td>
                <td>{{ food.fat }}</td>
                <td>{{ food.roughage }}</td>
                <td>{{ food.carbonhydrate }}</td>
                <td>{{ food.description }}</td>
                <td class="food-list-actions">
                    <button type="button" class="btn btn-primary" data-js="is-detail-btn" title="{{ "food.action.details" | trans }}"><i class="fas fa-magnifying-glass"></i></button>
                    <button type="button" class="btn btn-secondary" data-js="is-edit-btn" title="{{ "food.action.edit" | trans }}"><i class="fas fa-pencil"></i></button>
                    <button type="button" class="btn btn-danger" data-js="is-delete-btn" title="{{ "food.action.delete" | trans }}"><i class="fas fa-circle-minus"></i></button>
                </td>
            </tr>
        {% endfor %}
    </tbody>
    {% else %}
    <tbody>
        <tr>
            <td colspan="8">
                {{ "food.list.empty.message" | trans }}
            </td>
        </tr>
    </tbody>
    {% endif %}
</table>
{% endblock %}
