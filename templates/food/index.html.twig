{% extends 'base.html.twig' %}

{% block title %} - Food{% endblock %}

{% block body %}
    <h1>{{ "Foods"|trans }}</h1>

    <form id="searchFormFood" class="row">
        <div id="formError" class="form-text text-muted">Hier könnte Ihre Fehlermeldung stehen.</div>
        <div class="col-3">
            <div class="form-group">
                <label for="searchTerm"></label>
                <input type="text" id="searchTerm" placeholder="Hier Suchbegriff eingeben...">
            </div>
        </div>
        <div class="col-9">
            <div class="form-group">
                <input type="checkbox" id="searchInName">
                <label for="searchInName">Nach Name suchen</label>
            </div>
            <div class="form-group">
                <input type="checkbox" id="searchDescription">
                <label for="searchDescription">In Beschreibung suchen</label>
            </div>
        </div>
    </form>

    <table class="table">
        <thead>
        <tr>
            {% for headline in listHeadlines %}
                <th class="col">{{ headline|trans }}</th>
            {% endfor %}
            <th class="col">{{ "actions"|trans }}</th>
        </tr>
        </thead>
        <tfoot>
        <tr>
            <td colspan="3"></td>
            <td>
                <button type="button" class="btn btn-success" title="{{ "add"|trans }}">
                    <i class="fas fa-plus-circle"></i>
                </button>
            </td>
        </tr>
        </tfoot>
        <tbody>
        {% for food in foods %}
            <tr>
                <td>{{ food.name }}</td>
                <td>{{ food.description }}</td>
                <td>{{ food.nutritionValue }}</td>
                <td>
                    <div class="btn-group">
                        <button type="button" class="btn btn-secondary" title="{{ "details"|trans }}">
                            <i class="fas fa-info-circle"></i>
                        </button>
                        <button type="button" class="btn btn-primary" title="{{ "edit"|trans }}">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button type="button" class="btn btn-danger" title="{{ "delete"|trans }}">
                            <i class="fas fa-eraser"></i>
                        </button>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
